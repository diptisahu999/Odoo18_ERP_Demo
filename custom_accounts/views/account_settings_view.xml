<odoo>
    <!-- Accounting Setting Add this like Enterprise -->
    <record id="view_account_config_settings_inherit_import" model="ir.ui.view">
        <field name="name">account.config.settings.import.setup</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- ✅ EXACT anchor (no guess now) -->
            <xpath expr="//block[@name='default_taxes_setting_container']" position="before">
                <block title="Accounting Import" name="account_import_block">
                    <setting string="Initial Setup">
                        <div class="text-muted mb8">
                            Choose how you want to setup your CoA
                        </div>
                        <div class="mt8">
                            <button type="action"
                                    name="%(account.action_account_form)d"
                                    string="Review Manually (Opening Entries)"
                                    class="btn btn-primary"/>
                        </div>
                        <div class="mt8">
                             <button name="%(account.action_move_journal_line)d"
                                    type="action"
                                    string="Import Journal Entries"
                                    class="btn btn-secondary"/>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="view_account_tree_inherit_opening" model="ir.ui.view">
        <field name="name">account.account.list.opening</field>
        <field name="model">account.account</field>

        <!-- ✅ Correct parent -->
        <field name="inherit_id" ref="account.view_account_list"/>

        <field name="arch" type="xml">

            <!-- ✅ Odoo 18 uses <list>, NOT <tree> -->
            <xpath expr="//list" position="inside">
                <field name="opening_debit"/>
                <field name="opening_credit"/>
            </xpath>

        </field>
    </record>
    
</odoo>