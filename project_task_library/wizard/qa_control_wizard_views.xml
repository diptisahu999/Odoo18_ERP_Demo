<odoo>

    <record id="view_qa_control_wizard" model="ir.ui.view">
        <field name="name">qa.control.wizard.form</field>
        <field name="model">qa.control.wizard</field>
        <field name="arch" type="xml">
            <form string="Select QA Tasks">
                <group>
                    <field name="qa_task_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_done" type="object" string="Done" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>