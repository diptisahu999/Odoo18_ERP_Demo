<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Insert the "Add from Library" button into the project form header -->
    <record id="project_project_view_form_inherit_task_library_button" model="ir.ui.view">
        <field name="name">project.project.form.inherit.task.library.button</field>
        <field name="model">project.project</field>
        <!-- inherit whichever base project form exists; project.edit_project is commonly present -->
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- Insert button into existing header, not by creating a whole new header -->
            <xpath expr="//header" position="inside">
                <button name="%(project_task_library.action_task_library_wizard)d"
                        type="action"
                        string="Add from Library"
                        class="btn-secondary"/>
            </xpath>
        </field>
    </record>

    <record id="project_project_view_list_inherit_progress" model="ir.ui.view">
        <field name="name">project.project.list.inherit.progress</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="salesperson_id" string="Salesperson" optional="show"/>
                <field name="order_date" string="Order Date" optional="show"/>
                <field name="commitment_date" string="Delivery Date" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late" optional="show"/>
                <field name="x_remaining_days" widget="remaining_days" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late" string="Due Day" optional="show"/>
                <field name="x_is_late" column_invisible="True"/>
                <field name="x_is_today" column_invisible="True"/>
                <field name="amount_total" string="Order Value" widget="monetary" optional="show"/>
                <field name="x_project_progress" widget="progressbar" string="Progress" optional="show"
                    decoration-danger="x_project_progress &lt; 30"
                    decoration-warning="x_project_progress &gt;= 30 and x_project_progress &lt; 60"
                    decoration-info="x_project_progress &gt;= 60 and x_project_progress &lt; 80"
                    decoration-success="x_project_progress &gt;= 80"/>
            </xpath>
        </field>
    </record>

    <record id="project_project_view_list_inherit_progress_group" model="ir.ui.view">
        <field name="name">project.project.list.inherit.progress.group</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.project_list_view_group_stage"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="salesperson_id" string="Salesperson" optional="show"/>
                <field name="order_date" string="Order Date" optional="show"/>
                <field name="commitment_date" string="Delivery Date" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late" optional="show"/>
                <field name="x_remaining_days" widget="remaining_days" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late" string="Due Day" optional="show"/>
                <field name="x_is_late" column_invisible="True"/>
                <field name="x_is_today" column_invisible="True"/>
                <field name="amount_total" string="Order Value" widget="monetary" optional="show"/>
                <field name="x_project_progress" widget="progressbar" string="Progress" optional="show"
                    decoration-danger="x_project_progress &lt; 30"
                    decoration-warning="x_project_progress &gt;= 30 and x_project_progress &lt; 60"
                    decoration-info="x_project_progress &gt;= 60 and x_project_progress &lt; 80"
                    decoration-success="x_project_progress &gt;= 80"/>
            </xpath>
        </field>
    </record>

    <!-- Added new fields Get from SO -->
    <record id="project_project_view_form_inherit_customer" model="ir.ui.view">
        <field name="name">project.project.form.inherit.customer</field>
        <field name="model" >project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='label_tasks']" position="after">
                <field name="x_sale_order_id" readonly="1" string="Sale Order"/>
                <field name="partner_id" string="Customer" readonly="1"/>
                <field name="salesperson_id" string="Salesperson"/>
                <field name="amount_total" widget="monetary"/>
                <field name="order_date" string="Order Date"/>
                <field name="commitment_date" string="Delivery Date" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late"/>
                <field name="x_remaining_days" widget="remaining_days" decoration-danger="x_is_late" decoration-warning="x_is_today and not x_is_late" string="Due Day"/>
                <field name="x_is_late" invisible="1"/>
                <field name="x_is_today" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Added search view inheritance for Salesperson and Customer -->
    <record id="view_project_project_filter_inherit_sales" model="ir.ui.view">
        <field name="name">project.project.select.inherit.sales</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='Manager']" position="after">
                <filter string="Salesperson" name="salesperson" context="{'group_by': 'salesperson_id'}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="salesperson_id"/>
                <field name="order_date"/>
                <field name="commitment_date"/>
                <field name="x_remaining_days"/>
                <field name="amount_total"/>
            </xpath>
        </field>
    </record>

    <!-- Set List View as Default for Projects -->
    <record id="project.open_view_project_all" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="project.view_project"/>
    </record>

    <record id="project.open_view_project_all_group_stage" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="view_id" ref="project.project_list_view_group_stage"/>
    </record>

    <!-- QA Control -->
    <record id="view_project_form_qa_control" model="ir.ui.view">
        <field name="name">project.form.qa.control</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="QA Control">
                    <field name="qa_line_ids">
                        <list editable="bottom">
                            <field name="qa_id"/>

                            <field name="is_done"
                                attrs="{'readonly': [('is_done', '=', True)]}"/>

                            <field name="done_by" readonly="1"/>
                            <field name="done_date" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
