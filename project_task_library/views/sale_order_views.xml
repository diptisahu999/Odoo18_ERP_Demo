<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- "Create Project button Hide from Outer Header" -->
    <!-- When Create Project or Delivery Done -->
    <record id="view_order_form_inherit_project_task_library" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.project.task.library</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_project" 
                        string="Create Project" 
                        type="object" 
                        class="btn-primary" 
                        invisible="state not in ['draft', 'sent', 'sale'] 
                                or project_id != False 
                                or delivery_done == True"/>
            </xpath>
        </field>
    </record>
</odoo>
