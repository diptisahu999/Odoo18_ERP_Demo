<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_terms_and_conditions_tree" model="ir.ui.view">
        <field name="name">terms.and.conditions.tree</field>
        <field name="model">terms.and.conditions</field>
        <field name="arch" type="xml">
            <list string="Terms and Conditions Templates">
                <field name="name"/>
                <field name="terms_condition"/>
            </list>
        </field>
    </record>

    <record id="view_terms_and_conditions_form" model="ir.ui.view">
        <field name="name">terms.and.conditions.form</field>
        <field name="model">terms.and.conditions</field>
        <field name="arch" type="xml">
            <form string="Terms and Conditions Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="terms_condition"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_terms_and_conditions" model="ir.actions.act_window">
        <field name="name">Terms and Conditions Templates</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">terms.and.conditions</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menuitem to access settings -->
    <menuitem id="menu_terms_and_conditions"
              action="action_terms_and_conditions"
              parent="sale.menu_sale_config"
              sequence="100"/>
</odoo>
