<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_sale_terms_custom" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.sale_terms_custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="partner_invoice_id" string="Invoice Address" context="{'default_type':'invoice'}" options='{"always_reload": True}'/>
                <field name="partner_shipping_id" string="Delivery Address" context="{'default_type':'delivery'}" options='{"always_reload": True}'/>
            </field>
            <field name="payment_term_id" position="replace">
                <label for="payment_term_id"/>
                <div class="o_row">
                    <field name="payment_term_id" options="{'no_quick_create': False}" placeholder="Select Payment Terms..."/>
                    <button name="%(account.action_payment_term_form)d" type="action" icon="fa-plus" class="btn btn-link" title="Create New Payment Term" style="padding: 0;" target="new"/>
                </div>
                <label for="terms_condition_id" string="Terms and Condition"/>
                <div class="o_row">
                    <field name="terms_condition_id" options="{'no_quick_create': True}" placeholder="Select Terms Template..."/>
                    <button name="action_apply_terms" type="object" icon="fa-arrow-right" class="btn btn-link" title="Apply Terms" style="padding: 0;"/>
                    <button name="%(sale_terms_custom.action_terms_and_conditions)d" type="action" icon="fa-plus" class="btn btn-link" title="Create New Terms" style="padding: 0;" target="new"/>
                </div>
                <field name="additional_notes"/>
            </field>

            <!-- Override the Create Invoice buttons to perform availability check -->
            <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][1]" position="attributes">
                <attribute name="name">action_open_create_invoice_wizard</attribute>
                <attribute name="type">object</attribute>
            </xpath>
            <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d']" position="attributes">
                <attribute name="name">action_open_create_invoice_wizard</attribute>
                <attribute name="type">object</attribute>
            </xpath>
        </field>
    </record>
</odoo>
