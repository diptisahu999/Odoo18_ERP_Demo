<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.FormStatusIndicator" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o_form_button_save')]" position="attributes">
            <attribute name="class">o_form_button_save btn btn-primary px-3 py-1 me-2</attribute>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_save')]" position="inside">
            <t t-set="save_text">Save</t>
            <span class="o_form_button_save_text"><t t-esc="save_text"/></span>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_save')]/i" position="replace"/>

        <xpath expr="//button[hasclass('o_form_button_cancel')]" position="attributes">
            <attribute name="class">o_form_button_cancel btn btn-link px-2 py-1</attribute>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_cancel')]" position="inside">
            <t t-set="discard_text">Discard</t>
            <span class="o_form_button_discard_text"><t t-esc="discard_text"/></span>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_cancel')]/i" position="replace"/>
    </t>
</templates>
