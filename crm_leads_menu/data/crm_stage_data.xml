<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Stage 1: Lead -->
        <record id="stage_neotech_lead" model="crm.stage">
            <field name="name">Lead</field>
            <field name="sequence">10</field>
            <field name="is_won" eval="False"/>
        </record>

        <!-- Stage 2: Qualified Lead -->
        <record id="stage_neotech_qualified_lead" model="crm.stage">
            <field name="name">Qualified Lead</field>
            <field name="sequence">20</field>
            <field name="is_won" eval="False"/>
        </record>

        <!-- Stage 3: Proposal -->
        <record id="stage_neotech_proposal" model="crm.stage">
            <field name="name">Proposal</field>
            <field name="sequence">30</field>
            <field name="is_won" eval="False"/>
        </record>

        <!-- Stage 4: Negotiation -->
        <record id="stage_neotech_negotiation" model="crm.stage">
            <field name="name">Negotiation</field>
            <field name="sequence">40</field>
            <field name="is_won" eval="False"/>
        </record>

        <!-- Stage 5: Won (marks lead as won) -->
        <record id="stage_neotech_won" model="crm.stage">
            <field name="name">Won</field>
            <field name="sequence">50</field>
            <field name="is_won" eval="True"/>
        </record>

    </data>
</odoo>
